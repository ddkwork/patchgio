+// RenderInTextArea renders color indicators in the text area (not gutter).
+func (p *ColorIndicatorProvider) RenderInTextArea(gtx layout.Context, ctx gutter.GutterContext, gutterWidth int) {
+	indicatorSizePx := gtx.Dp(unit.Dp(indicatorSize))
+
+	fmt.Printf("[ColorIndicator] RenderInTextArea: viewport.Min.Y=%d, viewport.Max.Y=%d, gutterWidth=%d, totalLines=%d\n",
+		ctx.Viewport.Min.Y, ctx.Viewport.Max.Y, gutterWidth, len(ctx.Paragraphs))
+
+	// Debug: print all color info
+	fmt.Printf("[ColorIndicator] Total colorInfos: %d\n", len(p.colorInfos))
+	for line, colors := range p.colorInfos {
+		fmt.Printf("[ColorIndicator] Line %d: %d colors\n", line, len(colors))
+	}
+
+	// Render color indicators for each visible paragraph
+	for _, para := range ctx.Paragraphs {
+		colors, hasColors := p.colorInfos[para.Index]
+		if !hasColors || len(colors) == 0 {
+			continue
+		}
+
+		// Skip paragraphs outside the viewport
+		if para.EndY < ctx.Viewport.Min.Y {
+			fmt.Printf("[ColorIndicator] Skipping line %d: para.EndY=%d < viewport.Min.Y=%d\n",
+				para.Index, para.EndY, ctx.Viewport.Min.Y)
+			continue
+		}
+		if para.StartY > ctx.Viewport.Max.Y {
+			fmt.Printf("[ColorIndicator] Breaking at line %d: para.StartY=%d > viewport.Max.Y=%d\n",
+				para.Index, para.StartY, ctx.Viewport.Max.Y)
+			break
+		}
+
+		fmt.Printf("[ColorIndicator] Rendering color indicators for line %d: %d colors\n", para.Index, len(colors))
+		fmt.Printf("[ColorIndicator] Line %d: para.StartY=%d, para.EndY=%d, viewport.Min.Y=%d, viewport.Max.Y=%d, lineHeight=%d\n",
+			para.Index, para.StartY, para.EndY, ctx.Viewport.Min.Y, ctx.Viewport.Max.Y, ctx.LineHeight)
+
+		// Get line text to calculate pixel positions
+		lineText := p.getLineText(para.Index)
+		if lineText == "" {
+			continue
+		}
+
+		// Calculate line offset for converting global positions to line-relative positions
+		lineOffset := 0
+		for i := 0; i < para.Index; i++ {
+			prevLineText := p.getLineText(i)
+			if prevLineText == "" {
+				fmt.Printf("[ColorIndicator] Line %d: empty line, assuming 0 chars\n", i)
+				lineOffset += 1 // +1 for newline even for empty lines
+			} else {
+				fmt.Printf("[ColorIndicator] Calculating offset for line %d: prevLine=%d, prevLineText=%q, len=%d\n",
+					para.Index, i, prevLineText, len(prevLineText))
+				lineOffset += len(prevLineText) + 1 // +1 for newline
+			}
+		}
+		fmt.Printf("[ColorIndicator] Line %d: calculated offset=%d\n", para.Index, lineOffset)
+
+		// Layout: line text to get glyph positions
+		params := ctx.TextParams
+		params.MinWidth = 0
+		params.MaxLines = 1
+		ctx.Shaper.LayoutString(params, lineText)
+
+		fmt.Printf("[ColorIndicator] Line %d: lineText=%q, len=%d\n", para.Index, lineText, len(lineText))
+
+		// Collect glyph positions by tracking character offsets
+		glyphPositions := make([]int, len(lineText)+1)
+		currentPos := 0
+		for {
+			glyph, ok := ctx.Shaper.NextGlyph()
+			if !ok {
+				break
+			}
+			// Map glyph position to character positions
+			// glyph.Runes tells us how many characters this glyph represents
+			runesInGlyph := int(glyph.Runes)
+			for i := 0; i < runesInGlyph && currentPos < len(lineText); i++ {
+				glyphPositions[currentPos] = glyph.X.Floor()
+				currentPos++
+			}
+		}
+		// Fill remaining positions with the last known position
+		if currentPos < len(glyphPositions) {
+			lastPos := 0
+			if currentPos > 0 {
+				lastPos = glyphPositions[currentPos-1]
+			}
+			for currentPos < len(glyphPositions) {
+				glyphPositions[currentPos] = lastPos
+				currentPos++
+			}
+		}
+
+		// Render each color indicator on this line
+		for i, colorInfo := range colors {
+			// Calculate Y position: para.StartY is baseline, need to adjust for indicator center
+			// The indicator should be vertically centered with the text
+			baselineY := para.StartY - ctx.Viewport.Min.Y
+			ascent := para.Ascent.Ceil()
+			descent := para.Descent.Ceil()
+			textHeight := ascent + descent
+			// Center the indicator vertically with the text
+			indicatorY := baselineY - ascent + (textHeight-indicatorSizePx)/2
+
+			colorStartPos := colorInfo.Range.Start - lineOffset
+
+			fmt.Printf("[ColorIndicator] Color %d: globalStart=%d, lineOffset=%d, colorStartPos=%d, lineText=%q\n",
+				i, colorInfo.Range.Start, lineOffset, colorStartPos, lineText)
+			fmt.Printf("[ColorIndicator] Color %d: colorInfo.Original=%q, expected position in line: %d\n",
+				i, colorInfo.Original, strings.Index(lineText, colorInfo.Original))
+
+			if colorStartPos < 0 || colorStartPos >= len(lineText) {
+				fmt.Printf("[ColorIndicator] Skipping color %d: colorStartPos=%d out of range [0, %d)\n",
+					i, colorStartPos, len(lineText))
+				continue
+			}
+
+			// Calculate indicator X position: place it at the start of the color code
+			// but offset by indicator size + gap to avoid overlapping with text
+			var indicatorX int
+			if colorStartPos < len(glyphPositions) {
+				pos := glyphPositions[colorStartPos]
+				// Place indicator to the left of the color code, but ensure it doesn't overlap with previous text
+				indicatorX = max(pos-indicatorSizePx-4, 0)
+				fmt.Printf("[ColorIndicator] Color %d: glyphPos=%d, indicatorSizePx=%d, indicatorX=%d\n",
+					i, pos, indicatorSizePx, indicatorX)
+			} else {
+				indicatorX = 0
+				fmt.Printf("[ColorIndicator] Color %d: colorStartPos >= len(glyphPositions), using fallback indicatorX=%d\n",
+					i, indicatorX)
+			}
+
+			indicatorRect := image.Rect(indicatorX, indicatorY, indicatorX+indicatorSizePx, indicatorY+indicatorSizePx)
+
+			fmt.Printf("[ColorIndicator] Drawing indicator %d at (%d, %d) size %d, color=%v\n",
+				i, indicatorX, indicatorY, indicatorSizePx, colorInfo.Color)
+
+			pointer.CursorPointer.Add(gtx.Ops)
+			clip.Rect(indicatorRect).Push(gtx.Ops).Pop()
+			p.hoverer.Add(gtx.Ops)
+			p.clicker.Add(gtx.Ops)
+
+			stack := clip.Rect(indicatorRect).Push(gtx.Ops)
+			paint.FillShape(gtx.Ops, colorInfo.Color, clip.Rect(indicatorRect).Op())
+			stack.Pop()
+
+			if p.hoveredLine == para.Index && p.hoveredColorIndex == i {
+				borderColor := color.NRGBA{R: 0, G: 120, B: 215, A: 255}
+				borderWidth := 2
+				borderRect := image.Rect(
+					indicatorX-borderWidth,
+					indicatorY-borderWidth,
+					indicatorX+indicatorSizePx+borderWidth,
+					indicatorY+indicatorSizePx+borderWidth,
+				)
+				borderStack := clip.Rect(borderRect).Push(gtx.Ops)
+				paint.FillShape(gtx.Ops, borderColor, clip.Rect(borderRect).Op())
+				borderStack.Pop()
+			}
+		}
+	}
+}
+
+// getLineText returns the text content for a specific line
+func (p *ColorIndicatorProvider) getLineText(lineIndex int) string {
+	// Return the cached line text
+	if lineText, hasLineText := p.lineTexts[lineIndex]; hasLineText {
+		return lineText
+	}
+	return ""
+}
+
+// hitTestLine determines which logical line corresponds to a Y coordinate.
+func (p *ColorIndicatorProvider) hitTestLine(y int) int {
+	if len(p.paragraphs) == 0 {
+		return -1
+	}
+
+	for _, para := range p.paragraphs {
+		if y >= para.StartY && y <= para.EndY {
+			return para.Index
+		}
+	}
+
+	return -1
+}
+
+// hitTestColorIndex determines which color indicator on a line corresponds to an X coordinate.
+func (p *ColorIndicatorProvider) hitTestColorIndex(line int, x int, ctx gutter.GutterContext) int {
+	colors, hasColors := p.colorInfos[line]
+	if !hasColors || len(colors) == 0 {
+		return -1
+	}
+
+	indicatorSizePx := 16 // Fixed size in pixels for hit testing
+	gapPx := 2
+
+	for i := range colors {
+		xPos := gapPx + i*(indicatorSizePx+gapPx)
+		if x >= xPos && x <= xPos+indicatorSizePx {
+			return i
+		}
+	}
+
+	return -1
+}
