+		"var testColors = \"#FF0000 #00FF00 #0000FF #FFFF00 #800080 #FFA500\"",
+	}
+	startLine := 0
+	provider.SetLineContents(lines, startLine)
+
+	// Check that colors are detected
+	colors, hasColors := provider.colorInfos[0]
+	if !hasColors {
+		t.Error("Expected colors on line 0, but got none")
+		return
+	}
+
+	if len(colors) < 6 {
+		t.Errorf("Expected at least 6 colors, got %d", len(colors))
+		return
+	}
+
+	// Verify color positions are in the correct order
+	// Colors should be ordered by their start positions
+	for i := 1; i < len(colors); i++ {
+		if colors[i].Range.Start <= colors[i-1].Range.End {
+			t.Errorf("Color %d starts at %d, which is before or at the end of color %d (ends at %d)",
+				i, colors[i].Range.Start, i-1, colors[i-1].Range.End)
+		}
+	}
+
+	// Test with different line formats
+	testLines := []string{
+		"#FF0000",                     // Single color at start
+		"  #FF0000",                   // Color with leading spaces
+		"text #FF0000",                // Color after text
+		"text #FF0000 more text",      // Color in middle
+		"#FF0000 #00FF00",             // Two colors
+		"  #FF0000  #00FF00  #0000FF", // Multiple colors with spaces
+	}
+
+	for i, testLine := range testLines {
+		provider.SetLineContents([]string{testLine}, 0)
+		lineColors, hasColors := provider.colorInfos[0]
+		if hasColors {
+			for j, color := range lineColors {
+				// Check that color start position is valid
+				if color.Range.Start < 0 || color.Range.Start >= len(testLine) {
+					t.Errorf("Line %d, color %d: start position %d out of range [0, %d]",
+						i, j, color.Range.Start, len(testLine))
+				}
+				// Check that color end position is after start
+				if color.Range.End <= color.Range.Start {
+					t.Errorf("Line %d, color %d: end position %d is not after start %d",
+						i, j, color.Range.End, color.Range.Start)
+				}
+			}
+		}
+	}
+}
