+func TestColorIndicatorLineOffset(t *testing.T) {
+	provider := NewColorIndicatorProvider()
+
+	// Test case 1: Simple case with no empty lines
+	lines := []string{
+		"line 0",
+		"line 1",
+		"line 2",
+	}
+	startLine := 0
+	provider.SetLineContents(lines, startLine)
+
+	// Check line offsets
+	expectedOffsets := map[int]int{
+		0: 0,
+		1: 7,  // len("line 0") + 1 (newline)
+		2: 14, // len("line 0") + 1 + len("line 1") + 1
+	}
+
+	for lineNum, expectedOffset := range expectedOffsets {
+		lineText := provider.getLineText(lineNum)
+		if lineText == "" {
+			t.Errorf("Line %d: expected text %q, got empty", lineNum, lines[lineNum])
+			continue
+		}
+
+		// Calculate offset
+		offset := 0
+		for i := range lineNum {
+			prevLineText := provider.getLineText(i)
+			if prevLineText == "" {
+				offset += 1 // +1 for newline even for empty lines
+			} else {
+				offset += len(prevLineText) + 1 // +1 for newline
+			}
+		}
+
+		if offset != expectedOffset {
+			t.Errorf("Line %d: expected offset %d, got %d", lineNum, expectedOffset, offset)
+		}
+	}
+}
