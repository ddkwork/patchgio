+// ShowColorPicker returns whether the color picker should be shown.
+func (p *ColorIndicatorProvider) ShowColorPicker() bool {
+	fmt.Printf("[ColorIndicator] ShowColorPicker called: showPicker=%v, isPickerOpen=%v\n", p.showPicker, p.editorColorPicker.IsPickerOpen())
+	return p.showPicker
+}
+
+// CloseColorPicker closes color picker.
+func (p *ColorIndicatorProvider) CloseColorPicker() {
+	p.showPicker = false
+	p.editorColorPicker.HandleCancel()
+	fmt.Printf("[ColorIndicator] CloseColorPicker called: showPicker=%v\n", p.showPicker)
+}
