+func TestColorIndicatorOverlapDetection(t *testing.T) {
+	// Test case 5: Overlap detection
+	gutterWidth := 100
+	indicatorSize := 24
+	gap := 4
+
+	// Test case 1: No overlap (enough space between texts)
+	// indicatorX = gutterWidth + textPos - indicatorSize - gap
+	// prevTextEnd = gutterWidth + prevTextPos + gap
+	// For no overlap: indicatorX >= prevTextEnd
+	// 100 + textPos - 24 - 4 >= 100 + 30 + 4
+	// textPos >= 62
+	textPos := 62
+	prevTextPos := 30
+
+	indicatorX := gutterWidth + textPos - indicatorSize - gap
+	prevTextEnd := gutterWidth + prevTextPos + gap
+
+	if indicatorX < prevTextEnd {
+		t.Errorf("Expected no overlap, but indicatorX=%d < prevTextEnd=%d", indicatorX, prevTextEnd)
+	}
+
+	// Test case 2: With overlap (not enough space)
+	textPos = 35
+	prevTextPos = 30
+
+	indicatorX = gutterWidth + textPos - indicatorSize - gap
+	prevTextEnd = gutterWidth + prevTextPos + gap
+
+	if indicatorX >= prevTextEnd {
+		t.Errorf("Expected overlap, but indicatorX=%d >= prevTextEnd=%d", indicatorX, prevTextEnd)
+	}
+
+	// Test adjustment
+	adjustedX := prevTextEnd
+	expectedAdjustedX := 134 // 100 + 30 + 4 = 134
+	if adjustedX != expectedAdjustedX {
+		t.Errorf("Expected adjustedX=%d, got %d", expectedAdjustedX, adjustedX)
+	}
