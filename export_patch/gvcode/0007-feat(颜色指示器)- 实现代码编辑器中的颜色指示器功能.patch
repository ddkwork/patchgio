+				return layout.Dimensions{Size: image.Point{X: colorSize, Y: colorSize}}
+			})
+		}))
+	}
+
+	return layout.Flex{Axis: layout.Horizontal, Spacing: layout.SpaceEnd}.Layout(gtx, children...)
+}
